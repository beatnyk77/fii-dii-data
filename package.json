{
  "name": "fii-dii-dashboard",
  "version": "2.0.0",
  "description": "FII & DII Data Dashboard - Live Institutional Flow Tracker",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "production": "NODE_ENV=production node server.js",
    "pm2": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop fii-dii-dashboard",
    "pm2:restart": "pm2 restart fii-dii-dashboard",
    "pm2:logs": "pm2 logs fii-dii-dashboard",
    "fetch": "node scripts/fetch_data.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.5",
    "express": "^4.19.2",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
